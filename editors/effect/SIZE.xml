<?xml version="1.0" encoding="iso-8859-1"?>

<root>
    <windowclass name="effect_SIZE">
        <script file="editors/effect/scripts/SIZE.lua" />
		<margins control="0,0,0,2" />
        <sheetdata>
            <leftanchor_eb />

            <cycler_eb_valueholder name="size_mode">
                <anchored width="70" />
                <parameters mergerule="replace">
                    <defaultlabel>Category</defaultlabel>
                    <defaultvalue>Category</defaultvalue>
                    <labels>Step</labels>
                    <values>Step</values>
                </parameters>
            </cycler_eb_valueholder>

            <combobox_eb_size>
                <anchored>
                    <left offset="5" />
                </anchored>
            </combobox_eb_size>

            <cycler_eb_plus_minus />

            <number_eb_valueholder name="steps">
                <default>1</default>
                <hideonvalue>-1</hideonvalue>
                <min>1</min>
            </number_eb_valueholder>
        </sheetdata>
    </windowclass>
    <script name="loader_SIZE">
        function onInit()
            EditorManager.addEditor(
                "category_misc",
                {
                    value="SIZE",
                    labelres="effect_size",
                    windowclass="effect_SIZE"
                }
            )
        end
    </script>
</root>
