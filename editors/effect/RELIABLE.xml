                    <defaultlabel>Any Roll</defaultlabel>
                    <defaultvalue></defaultvalue>
                    <labels>Attack|Ability Check|Concentration|Death Save|Initiative|Saving Throw|Skill</labels>
                    <values>ATK|CHK|CONC|DEATH|INIT|SAV|SKILL</values>
                </parameters>
            </cycler_eb_valueholder>
        </sheetdata>
    </windowclass>
    <script name="loader_RELIABLE">
        function onInit()
            EditorManager.addEditor(
                "category_situational",
                {
                    value="RELIABLE",
                    labelres="effect_reliable",
                    windowclass="effect_RELIABLE"
                }
            )
        end
    </script>
</root>
